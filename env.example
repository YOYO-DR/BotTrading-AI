# ── MetaTrader 5 ──────────────────────────────
MT5_LOGIN=tu_numero_de_cuenta
MT5_PASSWORD=tu_contraseña
MT5_SERVER=NombreDelBroker-Server

# ── LLM Provider (elige uno) ──────────────────
OPENAI_API_KEY=sk-...
BASE_URL=https://api.tu-proveedor.com/v1
MODEL=gpt-4o

# Símbolos a analizar separados por comas.
# Usa comillas si incluyes símbolos con # (ej: GOLD#, BTCUSD#).
# También puedes definir lotaje por símbolo con formato SIMBOLO:LOTAJE
# Ejemplo: SYMBOLS="GOLD#:0.02,EURUSD:0.01,GBPUSD:0.015,BTCUSD#:0.01"
SYMBOLS="GOLD#,EURUSD,GBPUSD,BTCUSD#"

# Timeout por defecto (segundos) para llamados MCP/LLM.
CALL_TIMEOUT_SEC=100
# Opcionales para sobrescribir por tipo de llamado:
# MCP_CONNECT_TIMEOUT_SEC=100
# MCP_TOOL_TIMEOUT_SEC=100
# LLM_REQUEST_TIMEOUT_SEC=100

# ── Ventanas de ejecución (UTC) ───────────────
# Por defecto usa killzones del prompt convertidas a UTC:
# London Open + Session: 07:00-11:00 UTC
# NY Open + Session + London Close: 13:30-17:00 UTC
EXECUTION_WINDOWS_UTC=07:00-11:00,13:30-17:00

# Opcional: definir ventanas en hora Colombia (COT) y convertir automáticamente a UTC.
# Si defines EXECUTION_WINDOWS_COT, tiene prioridad sobre EXECUTION_WINDOWS_UTC.
# Ejemplo (London Open+Session y NY Open+Session+London Close):
# EXECUTION_WINDOWS_COT=02:00-06:00,08:30-12:00
# Offset COT respecto a UTC (Colombia = UTC-5):
# EXECUTION_COT_UTC_OFFSET_HOURS=-5

# Si quieres desactivar el filtro horario:
# ENFORCE_EXECUTION_WINDOWS=false

# ── Trading / Riesgo ───────────────────────────
# Lote fijo que el agente usará al ejecutar place_market_order/place_pending_order.
# El valor propuesto por el modelo será ignorado.
TRADE_LOT=0.01

# Requerir SL obligatorio al abrir con place_market_order.
REQUIRE_SL_ON_MARKET_ORDER=true

# Requerir TP en entrada. Si la orden entra sin TP, el flujo exige agregar TP con modify_position
# antes de aceptar decision=TRADE.
REQUIRE_TP_ON_ENTRY=true

# Antes de buscar nueva entrada, revisar posiciones abiertas del símbolo y reconciliar seguimiento
# de tickets cerrados en memoria (CLOSED_TP / CLOSED_SL / CLOSED_UNKNOWN).
POSITION_REVIEW_BEFORE_NEW_ENTRY=true

# Bloquear cualquier place_market_order fuera de ventanas operativas UTC.
BLOCK_ORDER_OUTSIDE_WINDOWS=true
